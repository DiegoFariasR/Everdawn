@page "/battle"
@using BattleSandbox.Web.Battle
@using BattleSandbox.Web.Services
@using GameCore.Battle
@using GameCore.Content
@using GameCore.Scenarios
@using System.Collections.Generic
@using System.Linq
@inject WebGameClient GameClient

<PageTitle>Battle Sandbox</PageTitle>

<div class="battle-page">

    <!-- == Scenario picker card ============================================ -->
    <section class="card picker">
        <div class="picker-row">
            <label for="scenario">Scenario</label>
            <select id="scenario" @bind="_selectedScenarioId">
                @foreach (var s in _scenarios)
                {
                    <option value="@s.Id">@s.DisplayName</option>
                }
            </select>
            <button class="btn-run" @onclick="StartSession">▶ Start</button>
        </div>
        <div class="picker-row">
            <label for="auto-speed">Speed</label>
            <select id="auto-speed" @bind="_autoDelay">
                <option value="1000">1× (1 s/turn)</option>
                <option value="333">3× (0.33 s)</option>
                <option value="200">5× (0.2 s)</option>
            </select>
            <button class="btn-auto @(_autoMode ? "btn-auto-on" : "")" @onclick="ToggleAuto">
                Auto @(_autoMode ? "ON" : "OFF")
            </button>
        </div>
    </section>

    @if (_startError != null)
    {
        <div class="error-banner">Error: @_startError</div>
    }

    <!-- == Play mode ======================================================= -->
    @if (_playMode && _view != null && _setup != null)
    {
        var  state       = _view.Units;
        var  lastEv      = _view.FullLog.LastOrDefault();
        var  pending     = _view.PendingInput;
        string evType    = lastEv?.Type ?? "start";
        string? activeId = pending?.ActorId ?? lastEv?.ActorId;
        bool targetIsAlly = pending != null && (_pendingSkill?.Target == BattleSkillTarget.Ally);
        bool pendingIsAoe = _pendingSkill?.IsAoe ?? false;

        <TurnStrip PlayerUnits="_setup.PlayerUnits" EnemyUnits="_setup.EnemyUnits"
                   UnitStates="state" ActiveUnitId="activeId" Round="_view.Round" />

        <CurrentEventCard EventType="evType"
                          Description="@(lastEv?.Description ?? "Battle begins!")" />

        <Battleground PlayerUnits="_setup.PlayerUnits" EnemyUnits="_setup.EnemyUnits"
                      UnitStates="state" ActiveUnitId="activeId"
                      Floats="_floats" MeleeAnimators="_meleeAnimators"
                      SelectedSkillId="_pendingAction"
                      PendingTargetIsAlly="targetIsAlly"
                      PendingIsAoe="pendingIsAoe"
                      HasPendingInput="pending != null"
                      AutoMode="_autoMode"
                      OnUnitTargeted="ConfirmTarget" />

        <ActiveCharCard Pending="pending"
                        ActiveEnemyUnit="@(pending == null && !_view.IsOver
                            ? _setup.EnemyUnits.FirstOrDefault(u => u.Id == activeId)
                            : null)"
                        LastEventSkillId="lastEv?.SkillId"
                        IsOver="_view.IsOver" WinningTeam="_view.WinningTeam"
                        AutoMode="_autoMode"
                        SelectedSkillId="_pendingAction"
                        AutoSkillId="_autoSkillId"
                        OnSkillSelect="@(id => { _pendingAction = id; })"
                        OnAoeFire="FireAoe"
                        OnAutoFire="AutoFireSkill"
                        OnRetry="StartSession" />

        <BattleLogPanel Events="_view.FullLog" IsPlayMode="true" AutoMode="_autoMode"
                        NewEventsStart="_lastActionEventStart"
                        OnEntryClick="UndoToEvent" />
    }

    <!-- == Watch mode ======================================================= -->
    @if (!_playMode && _result != null && _setup != null)
    {
        var snap      = CurrentSnapshot!;
        string? snapActor = snap.Event.ActorId;
        var emptyFloats   = Enumerable.Empty<FloatNumber>();
        var emptySet      = new HashSet<string>();

        <TurnStrip PlayerUnits="_setup.PlayerUnits" EnemyUnits="_setup.EnemyUnits"
                   UnitStates="snap.UnitStates" ActiveUnitId="snapActor"
                   Round="WatchRound" />

        <CurrentEventCard EventType="snap.Event.Type" Description="snap.Event.Description" />

        <Battleground PlayerUnits="_setup.PlayerUnits" EnemyUnits="_setup.EnemyUnits"
                      UnitStates="snap.UnitStates" ActiveUnitId="snapActor"
                      Floats="emptyFloats" MeleeAnimators="emptySet"
                      AutoMode="true" HasPendingInput="false" />

        <StepControls CurrentStep="_step" TotalSteps="_result.Snapshots.Count"
                      OnJumpStart="JumpToStart" OnStepBack="StepBack"
                      OnStepForward="StepForward" OnJumpEnd="JumpToEnd"
                      OnTakeControl="TakeControlFromHere" />

        <BattleLogPanel Events="_watchEvents" IsPlayMode="false" CurrentStep="_step"
                        OnEntryClick="@(idx => _step = idx)" />
    }

</div>

@code {
    // Shared
    private List<IBattleScenario> _scenarios = new List<IBattleScenario>();
    private string _selectedScenarioId = "";
    private IBattleScenario? _currentScenario;
    private BattleSetup? _setup;
    private bool _playMode;
    private string? _startError;

    protected override void OnInitialized()
    {
        _scenarios = ScenarioRegistry.All.ToList();
        _selectedScenarioId = _scenarios[0].Id;
    }

    // Play mode
    private IBattleEngine? _engine;
    private BattleView?    _view;
    private string?        _pendingAction;
    private bool           _autoMode;
    private int            _autoDelay = 1000;
    private int            _lastActionEventStart;

    private SkillView? _pendingSkill =>
        _view?.PendingInput?.Skills.FirstOrDefault(s => s.Id == _pendingAction);

    private string? _autoSkillId
    {
        get
        {
            var p = _view?.PendingInput;
            if (p is null) return null;
            return p.Skills.LastOrDefault(s => p.AvailableSkillIds.Contains(s.Id))?.Id;
        }
    }

    // Command history (undo)
    private record CommandRecord(BattleCommand Cmd, int LogCountBefore);
    private List<CommandRecord> _commandHistory = new List<CommandRecord>();
    private ResumeFromSnapshotCommand? _resumeCommand;

    // Watch mode
    private BattleResult? _result;
    private int           _step;

    private BattleSnapshot? CurrentSnapshot => _result?.Snapshots[_step];

    private IReadOnlyList<BattleEvent> _watchEvents =>
        _result != null
            ? (IReadOnlyList<BattleEvent>)_result.Snapshots.Select(s => s.Event).ToList()
            : System.Array.Empty<BattleEvent>();

    private int WatchRound =>
        _result == null ? 0
        : 1 + _result.Snapshots.Take(_step).Count(s => s.Event.Type == "round");

    // Session start
    private void StartSession()
    {
        _startError = null;
        try { StartSessionInner(); }
        catch (System.Exception ex)
        {
            _startError = ex.Message
                + (ex.InnerException != null ? " → " + ex.InnerException.Message : "");
        }
    }

    private void StartSessionInner()
    {
        _currentScenario = _scenarios.First(s => s.Id == _selectedScenarioId);
        _setup           = _currentScenario.CreateSetup(GameClient.ContentSource);
        _playMode        = _currentScenario.IsPlayable;
        _engine          = null;
        _view            = null;
        _result          = null;
        _pendingAction   = null;

        BuildSkillRanges();
        _playerUnitIds.Clear();
        foreach (var u in _setup.PlayerUnits) _playerUnitIds.Add(u.Id);
        _meleeAnimators.Clear();

        if (_playMode)
        {
            _resumeCommand  = null;
            _commandHistory = new List<CommandRecord>();
            _engine = new BattleSession(_currentScenario.Seed);
            _view   = _engine.Start(_setup).View;
            SelectDefaultSkill();
            if (_autoMode) _ = RunAutoAsync();
        }
        else
        {
            _result = BattleSession.RunFull(_setup, _currentScenario.Seed);
            _step   = 0;
        }
    }

    private void TakeControlFromHere()
    {
        if (_result == null || _setup == null || _currentScenario == null) return;
        var snap        = _result.Snapshots[_step];
        _resumeCommand  = new ResumeFromSnapshotCommand(snap.UnitStates, snap.Event.ActorId, _step + 1);
        _commandHistory = new List<CommandRecord>();
        _engine = new BattleSession(_currentScenario.Seed);
        _engine.Start(_setup);
        _view     = _engine.TryExecute(_resumeCommand).View;
        _playMode = true;
        _result   = null;
        SelectDefaultSkill();
        if (_autoMode) _ = RunAutoAsync();
    }

    // Auto-play
    private void ToggleAuto()
    {
        _autoMode = !_autoMode;
        if (_autoMode && _engine != null && _view?.PendingInput != null && !_view.IsOver)
            _ = RunAutoAsync();
    }

    private async System.Threading.Tasks.Task RunAutoAsync()
    {
        while (_autoMode && _engine != null && !(_view?.IsOver ?? true))
        {
            await System.Threading.Tasks.Task.Delay(_autoDelay);
            if (!_autoMode || _engine == null) break;
            var cmd = new AdvanceTurnCommand();
            _commandHistory.Add(new CommandRecord(cmd, _view!.FullLog.Count));
            var result = _engine.TryExecute(cmd);
            _view = result.View;
            TriggerMeleeAnims(result.Events);
            SpawnFloats(result.Events);
            SelectDefaultSkill();
            StateHasChanged();
        }
    }

    // Player actions
    private void FireAoe(string skillId)
    {
        if (_engine is null) return;
        _lastActionEventStart = _view!.FullLog.Count;
        var cmd = new PlayerActionCommand(skillId, null);
        _commandHistory.Add(new CommandRecord(cmd, _view.FullLog.Count));
        var result = _engine.TryExecute(cmd);
        _view = result.View;
        TriggerMeleeAnims(result.Events);
        SpawnFloats(result.Events);
        SelectDefaultSkill();
        if (!_autoMode) _ = AdvanceNonPlayerTurnsAsync();
    }

    private void AutoFireSkill(string skillId)
    {
        if (_engine is null || _setup is null || _view is null || _pendingAction is null) return;
        var pending = _view.PendingInput;
        if (pending is null) return;
        var skill = _pendingSkill;
        if (skill is null) return;

        var targets = skill.Target == BattleSkillTarget.Ally
            ? (System.Collections.Generic.IReadOnlyList<BattleUnit>)_setup.PlayerUnits
            : _setup.EnemyUnits;
        var autoTarget = System.Linq.Enumerable.FirstOrDefault(targets,
            u => _view.Units.FirstOrDefault(s => s.UnitId == u.Id)?.IsAlive ?? false);
        if (autoTarget != null) ConfirmTarget(autoTarget.Id);
    }

    private void ConfirmTarget(string targetId)
    {
        if (_engine is null || _pendingAction is null) return;
        _lastActionEventStart = _view!.FullLog.Count;
        var cmd = new PlayerActionCommand(_pendingAction, targetId);
        _commandHistory.Add(new CommandRecord(cmd, _view.FullLog.Count));
        var result = _engine.TryExecute(cmd);
        _view = result.View;
        TriggerMeleeAnims(result.Events);
        SpawnFloats(result.Events);
        SelectDefaultSkill();
        if (!_autoMode) _ = AdvanceNonPlayerTurnsAsync();
    }

    private async System.Threading.Tasks.Task AdvanceNonPlayerTurnsAsync()
    {
        while (_engine != null && !(_view?.IsOver ?? true) && _view?.PendingInput == null)
        {
            await System.Threading.Tasks.Task.Delay(_autoDelay);
            if (_engine == null || _autoMode) break;
            var cmd = new AdvanceTurnCommand();
            _commandHistory.Add(new CommandRecord(cmd, _view!.FullLog.Count));
            var result = _engine.TryExecute(cmd);
            _view = result.View;
            TriggerMeleeAnims(result.Events);
            SpawnFloats(result.Events);
            SelectDefaultSkill();
            StateHasChanged();
        }
    }

    // Undo
    private void UndoToEvent(int logIndex)
    {
        if (_engine == null || _setup == null || _currentScenario == null || _autoMode) return;

        int actionsToReplay = 0;
        for (int j = 0; j < _commandHistory.Count; j++)
        {
            int nextLogCount = j + 1 < _commandHistory.Count
                ? _commandHistory[j + 1].LogCountBefore
                : _view!.FullLog.Count;
            if (nextLogCount <= logIndex) actionsToReplay = j + 1;
            else break;
        }

        var newEng = new BattleSession(_currentScenario.Seed);
        BattleView v = newEng.Start(_setup).View;
        if (_resumeCommand != null) v = newEng.TryExecute(_resumeCommand).View;
        for (int j = 0; j < actionsToReplay; j++)
            v = newEng.TryExecute(_commandHistory[j].Cmd).View;

        _engine         = newEng;
        _view           = v;
        _commandHistory = _commandHistory.Take(actionsToReplay).ToList();
        _lastActionEventStart = 0;
        _floats.Clear();
        SelectDefaultSkill();
    }

    private void SelectDefaultSkill()
    {
        var p = _view?.PendingInput;
        if (p is null) { _pendingAction = null; return; }
        var def = p.Skills.LastOrDefault(s => p.AvailableSkillIds.Contains(s.Id));
        _pendingAction = def?.Id;
    }

    // Watch mode
    private void StepForward() => _step = System.Math.Min(_step + 1, (_result?.Snapshots.Count ?? 1) - 1);
    private void StepBack()    => _step = System.Math.Max(0, _step - 1);
    private void JumpToStart() => _step = 0;
    private void JumpToEnd()   => _step = (_result?.Snapshots.Count ?? 1) - 1;

    // Melee animations
    private readonly HashSet<string> _meleeAnimators = new HashSet<string>();
    private Dictionary<string, SkillRange> _skillRanges = new Dictionary<string, SkillRange>();
    private readonly HashSet<string> _playerUnitIds = new HashSet<string>();

    private void BuildSkillRanges()
    {
        if (_setup == null) return;
        _skillRanges = _setup.PlayerUnits
            .Concat(_setup.EnemyUnits)
            .SelectMany(u => u.ResolvedSkills)
            .GroupBy(s => s.Id)
            .ToDictionary(g => g.Key, g => g.First().Range);
    }

    private void TriggerMeleeAnims(IReadOnlyList<BattleEvent>? events)
    {
        if (events is null) return;
        foreach (var ev in events)
        {
            if (ev.SkillId is null || ev.TargetId is null) continue;
            if (!_skillRanges.TryGetValue(ev.SkillId, out var range) || range != SkillRange.Melee) continue;
            _meleeAnimators.Add(ev.ActorId);
        }
        if (_meleeAnimators.Count > 0) _ = ExpireMeleeAnimsAsync();
    }

    private async System.Threading.Tasks.Task ExpireMeleeAnimsAsync()
    {
        await System.Threading.Tasks.Task.Delay(700);
        _meleeAnimators.Clear();
        StateHasChanged();
    }

    // Floating numbers
    private readonly List<FloatNumber> _floats = new List<FloatNumber>();
    private int _floatKey;

    private void SpawnFloats(IReadOnlyList<BattleEvent>? events)
    {
        if (events is null) return;
        foreach (var ev in events)
        {
            if (ev.TargetId is null || ev.Value <= 0) continue;
            bool isHeal = ev.SkillId != null && ev.EffectType == null;
            int  offset = 20 + (_floatKey % 5) * 12;
            _floats.Add(new FloatNumber(ev.TargetId, ev.Value, isHeal, offset, _floatKey++));
        }
        if (_floats.Count > 0) _ = ExpireFloatsAsync();
    }

    private async System.Threading.Tasks.Task ExpireFloatsAsync()
    {
        await System.Threading.Tasks.Task.Delay(1100);
        _floats.Clear();
        StateHasChanged();
    }
}

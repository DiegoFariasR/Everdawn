@page "/"
@using GameCore.Battle
@using GameCore.Scenarios

<PageTitle>Battle Sandbox</PageTitle>

<div class="sandbox">

    <!-- ── Picker bar ─────────────────────────────────────────── -->
    <section class="picker">
        <div class="picker-row">
            <label for="scenario">Scenario</label>
            <select id="scenario" @bind="_selectedScenarioId">
                @foreach (var s in _scenarios)
                {
                    <option value="@s.Id">@s.DisplayName @(s.IsPlayable ? "🎮" : "👁")</option>
                }
            </select>
            <button class="btn-run" @onclick="StartSession">▶ Start</button>
        </div>
        <div class="picker-row">
            <label for="auto-speed">Speed</label>
            <select id="auto-speed" @bind="_autoDelay">
                <option value="600">Fast</option>
                <option value="1200">Normal</option>
                <option value="2400">Slow</option>
            </select>
            <button class="btn-auto @(_autoMode ? "btn-auto-on" : "")" @onclick="ToggleAuto">
                ⚡ Auto @(_autoMode ? "ON" : "OFF")
            </button>
        </div>
    </section>

    @if (_playMode && _response != null && _setup != null)
    {
        var state   = _response.State;
        var lastEv  = _response.FullLog.LastOrDefault();
        string evType = lastEv?.Type ?? "start";
        var pending = _response.PendingInput;
        var pendingSkill = _pendingAction != null ? pending?.Skills.FirstOrDefault(s => s.Id == _pendingAction) : null;
        bool pendingTargetIsAlly = pendingSkill?.Target == BattleSkillTarget.Ally;
        bool pendingIsAoe        = pendingSkill?.IsAoe ?? false;
        string? activeUnitId = pending?.Actor.Id ?? lastEv?.ActorId;

        <section class="portrait-strip">
            @foreach (var u in _setup.PlayerUnits)
            {
                var st = state.First(s => s.UnitId == u.Id);
                <div class="portrait player-portrait
                    @(activeUnitId == u.Id ? "portrait-active" : "")
                    @(!st.IsAlive ? "portrait-dead" : "")">
                    @u.Name[0]
                </div>
            }
            <div class="portrait-sep">⚔</div>
            @foreach (var u in _setup.EnemyUnits)
            {
                var st = state.First(s => s.UnitId == u.Id);
                <div class="portrait enemy-portrait
                    @(activeUnitId == u.Id ? "portrait-active" : "")
                    @(!st.IsAlive ? "portrait-dead" : "")">
                    @u.Name[0]
                </div>
            }
        </section>

        <section class="current-event @evType">
            @(lastEv?.Description ?? "Battle begins!")
        </section>

        <section class="arena">
            <div class="team player-team">
                @foreach (var u in _setup.PlayerUnits)
                {
                    var st = state.First(s => s.UnitId == u.Id);
                    int hpPct = u.MaxHp > 0 ? st.CurrentHp * 100 / u.MaxHp : 0;
                    int mpPct = u.MaxMp > 0 ? st.CurrentMp * 100 / u.MaxMp : 0;
                    string hpColor = hpPct > 50 ? "#44cc44" : hpPct > 25 ? "#ffaa00" : "#cc4444";
                    bool canHealTarget = pendingTargetIsAlly && !pendingIsAoe && _pendingAction != null && st.IsAlive && !_autoMode;
                    <div class="unit-card
                        @(activeUnitId == u.Id ? "card-active" : "")
                        @(!st.IsAlive ? "card-dead" : "")
                        @(canHealTarget ? "card-targetable card-heal-target" : "")"
                        style="position:relative"
                        @onclick="() => { if (canHealTarget) ConfirmTarget(u.Id); }">
                        @foreach (var f in _floats.Where(f => f.UnitId == u.Id))
                        {
                            <span class="float-num @(f.IsHeal ? "float-heal" : "float-dmg")" style="left:@(f.OffsetPct)%" @key="f.Key">@(f.IsHeal ? "+" : "-")@f.Value</span>
                        }
                        <div class="avatar player-avatar">@u.Name[0]</div>
                        <div class="unit-info">
                            <div class="unit-name">@u.Name <span class="unit-lv">Lv.@u.Level</span></div>
                            <div class="bar-wrap"><div class="hp-bar" style="width:@hpPct%;background:@hpColor"></div></div>
                            @if (u.MaxMp > 0)
                            {
                                <div class="bar-wrap"><div class="mp-bar" style="width:@mpPct%"></div></div>
                            }
                            <div class="stat-text">@st.CurrentHp/@u.MaxHp HP &nbsp;|&nbsp; STR @u.Str &nbsp;WIS @u.Wis &nbsp;AGI @u.Agi</div>
                        </div>
                    </div>
                }
            </div>

            <div class="vs-col">vs</div>

            <!-- Enemy team — clickable for target selection -->
            <div class="team enemy-team">
                @foreach (var u in _setup.EnemyUnits)
                {
                    var st = state.First(s => s.UnitId == u.Id);
                    int hpPct = u.MaxHp > 0 ? st.CurrentHp * 100 / u.MaxHp : 0;
                    string hpColor = hpPct > 50 ? "#44cc44" : hpPct > 25 ? "#ffaa00" : "#cc4444";
                    bool canTarget = pending != null && _pendingAction != null && !pendingIsAoe && st.IsAlive && !_autoMode && !pendingTargetIsAlly;

                    <div class="unit-card
                        @(activeUnitId == u.Id ? "card-active" : "")
                        @(!st.IsAlive ? "card-dead" : "")
                        @(canTarget ? "card-targetable" : "")"
                        style="position:relative"
                        @onclick="() => { if (canTarget) ConfirmTarget(u.Id); }">
                        @foreach (var f in _floats.Where(f => f.UnitId == u.Id))
                        {
                            <span class="float-num @(f.IsHeal ? "float-heal" : "float-dmg")" style="left:@(f.OffsetPct)%" @key="f.Key">@(f.IsHeal ? "+" : "-")@f.Value</span>
                        }
                        <div class="avatar enemy-avatar">@u.Name[0]</div>
                        <div class="unit-info">
                            <div class="unit-name">@u.Name <span class="unit-lv">Lv.@u.Level</span></div>
                            <div class="bar-wrap"><div class="hp-bar" style="width:@hpPct%;background:@hpColor"></div></div>
                            <div class="stat-text">@st.CurrentHp/@u.MaxHp HP &nbsp;|&nbsp; STR @u.Str &nbsp;WIS @u.Wis &nbsp;AGI @u.Agi</div>
                        </div>
                    </div>
                }
            </div>
        </section>

        @if (pending != null)
        {
            <section class="action-bar">
                <div class="acting-label">
                    @(pending.Actor.Name + "'s turn")
                </div>
                @if (_autoMode)
                {
                    <div class="action-buttons">
                        <span style="opacity:0.6">⚡ Auto resolving…</span>
                    </div>
                }
                else
                {
                    <div class="action-buttons">
                        @for (int si = 0; si < pending.Skills.Count; si++)
                        {
                            var skill        = pending.Skills[si];
                            bool canUse      = pending.AvailableSkillIds.Contains(skill.Id);
                            bool isSelected  = skill.Id == _pendingAction;
                            string btnClass  = si == 0 ? "btn-attack" : si == 1 ? "btn-skill" : "btn-soulburn";
                            string skillId   = skill.Id;
                            bool isAoe       = skill.IsAoe;
                            bool isAllySkill = skill.Target == BattleSkillTarget.Ally;
                            int  cdLeft      = pending.SkillCooldowns.GetValueOrDefault(skill.Id);
                            <button class="btn-action @btnClass @(isAoe ? "btn-aoe" : "") @(isAllySkill ? "btn-heal" : "") @(isSelected ? "btn-selected" : "")"
                                    disabled="@(!canUse)"
                                    @onclick="() => { if (isAoe) FireAoe(skillId); else _pendingAction = skillId; }">
                                @skill.Name
                                @if (isAoe) { <span class="aoe-badge">ALL</span> }
                                @if (isAllySkill) { <span class="ally-badge">ALLY</span> }
                                @if (cdLeft > 0) { <span class="cd-badge">CD @cdLeft</span> }
                                else if (skill.MpCost > 0) { <span class="mp-cost">@skill.MpCost MP</span> }
                                @if (cdLeft == 0 && skill.Cooldown > 0) { <span class="cd-cost">→@skill.Cooldown</span> }
                            </button>
                        }
                    </div>
                }
            </section>
        }
        else if (_response.IsOver)
        {
            <section class="battle-over @(_response.WinningTeam == "player" ? "over-win" : "over-lose")">
                @(_response.WinningTeam == "player" ? "⚔ Victory!" : "💀 Defeat...")
                <button class="btn-run" style="margin-left:1rem" @onclick="StartSession">Retry</button>
            </section>
        }

        <section class="event-log play-log" id="play-log">
            @for (int i = 0; i < _response.FullLog.Count; i++)
            {
                var ev  = _response.FullLog[i];
                bool isLast = i == _response.FullLog.Count - 1;
                int  idx = i;
                <div class="event-entry @ev.Type @(isLast ? "event-current" : "")"
                     title="@(!_autoMode ? "Click to undo to this point" : "")"
                     @onclick="() => UndoToEvent(idx)">
                    @ev.Description
                </div>
            }
        </section>
    }

    @if (!_playMode && _result != null && _setup != null)
    {
        var snap = CurrentSnapshot!;

        <section class="portrait-strip">
            @foreach (var u in _setup.PlayerUnits)
            {
                var st = snap.UnitStates.First(s => s.UnitId == u.Id);
                <div class="portrait player-portrait @(snap.Event.ActorId == u.Id ? "portrait-active" : "") @(!st.IsAlive ? "portrait-dead" : "")">
                    @u.Name[0]
                </div>
            }
            <div class="portrait-sep">⚔</div>
            @foreach (var u in _setup.EnemyUnits)
            {
                var st = snap.UnitStates.First(s => s.UnitId == u.Id);
                <div class="portrait enemy-portrait @(snap.Event.ActorId == u.Id ? "portrait-active" : "") @(!st.IsAlive ? "portrait-dead" : "")">
                    @u.Name[0]
                </div>
            }
        </section>

        <section class="current-event @snap.Event.Type">@snap.Event.Description</section>

        <section class="arena">
            <div class="team player-team">
                @foreach (var u in _setup.PlayerUnits)
                {
                    var st = snap.UnitStates.First(s => s.UnitId == u.Id);
                    int hpPct = u.MaxHp > 0 ? st.CurrentHp * 100 / u.MaxHp : 0;
                    int mpPct = u.MaxMp > 0 ? st.CurrentMp * 100 / u.MaxMp : 0;
                    string hpColor = hpPct > 50 ? "#44cc44" : hpPct > 25 ? "#ffaa00" : "#cc4444";
                    <div class="unit-card @(snap.Event.ActorId == u.Id ? "card-active" : "") @(!st.IsAlive ? "card-dead" : "")">
                        <div class="avatar player-avatar">@u.Name[0]</div>
                        <div class="unit-info">
                            <div class="unit-name">@u.Name <span class="unit-lv">Lv.@u.Level</span></div>
                            <div class="bar-wrap"><div class="hp-bar" style="width:@hpPct%;background:@hpColor"></div></div>
                            @if (u.MaxMp > 0) { <div class="bar-wrap"><div class="mp-bar" style="width:@mpPct%"></div></div> }
                            <div class="stat-text">@st.CurrentHp/@u.MaxHp HP</div>
                        </div>
                    </div>
                }
            </div>
            <div class="vs-col">vs</div>
            <div class="team enemy-team">
                @foreach (var u in _setup.EnemyUnits)
                {
                    var st = snap.UnitStates.First(s => s.UnitId == u.Id);
                    int hpPct = u.MaxHp > 0 ? st.CurrentHp * 100 / u.MaxHp : 0;
                    int mpPct = u.MaxMp > 0 ? st.CurrentMp * 100 / u.MaxMp : 0;
                    string hpColor = hpPct > 50 ? "#44cc44" : hpPct > 25 ? "#ffaa00" : "#cc4444";
                    <div class="unit-card @(snap.Event.ActorId == u.Id ? "card-active" : "") @(!st.IsAlive ? "card-dead" : "")">
                        <div class="avatar enemy-avatar">@u.Name[0]</div>
                        <div class="unit-info">
                            <div class="unit-name">@u.Name <span class="unit-lv">Lv.@u.Level</span></div>
                            <div class="bar-wrap"><div class="hp-bar" style="width:@hpPct%;background:@hpColor"></div></div>
                            @if (u.MaxMp > 0) { <div class="bar-wrap"><div class="mp-bar" style="width:@mpPct%"></div></div> }
                            <div class="stat-text">@st.CurrentHp/@u.MaxHp HP</div>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="step-controls">
            <button @onclick="JumpToStart">◀◀</button>
            <button @onclick="StepBack">◀</button>
            <span class="step-label">@(_step + 1) / @_result.Snapshots.Count</span>
            <button @onclick="StepForward">▶</button>
            <button @onclick="JumpToEnd">▶▶</button>            <button class="btn-takeover" @onclick="TakeControlFromHere" title="Play from here">⚔ Take Control</button>        </section>

        <section class="event-log">
            @for (int i = 0; i < _result.Snapshots.Count; i++)
            {
                int idx = i;
                var s = _result.Snapshots[i];
                <div class="event-entry @(idx == _step ? "event-current" : "") @s.Event.Type" @onclick="() => _step = idx">
                    <span class="event-num">@(i + 1).</span> @s.Event.Description
                </div>
            }
        </section>
    }

</div>

@code {
    // ── Shared ──────────────────────────────────────────────────
    private List<IBattleScenario> _scenarios = [];
    private string _selectedScenarioId = "";
    private IBattleScenario? _currentScenario;
    private BattleSetup? _setup;
    private bool _playMode;

    // ── Play mode ────────────────────────────────────────────────
    private InteractiveBattleSession? _session;
    private BattleResponse? _response;
    private string? _pendingAction;   // skill ID selected, waiting for target
    private bool _autoMode;
    private int _autoDelay = 600;

    // ── Action history (for undo) ────────────────────────────────
    private record ActionRecord(bool IsAuto, string? SkillId, string? TargetId, int LogCountBefore);
    private List<ActionRecord> _actionHistory = [];
    private BattleRequest? _startRequest;

    // ── Watch mode ───────────────────────────────────────────────
    private BattleResult? _result;
    private int _step;

    protected override void OnInitialized()
    {
        _scenarios = [new SampleScenario(), new SampleScenarioWatch()];
        _selectedScenarioId = _scenarios[0].Id;
    }

    private void StartSession()
    {
        _currentScenario = _scenarios.First(s => s.Id == _selectedScenarioId);
        _setup         = _currentScenario.CreateSetup();
        _playMode      = _currentScenario.IsPlayable;
        _session       = null;
        _response      = null;
        _result        = null;
        _pendingAction = null;

        if (_playMode)
        {
            _startRequest  = new StartBattleRequest();
            _actionHistory = [];
            _session  = new InteractiveBattleSession(_setup, _currentScenario.Seed);
            _response = _session.HandleRequest(_startRequest);
            SelectDefaultSkill();
            if (_autoMode) _ = RunAutoAsync();
        }
        else
        {
            _result = BattleEngine.Run(_setup, _currentScenario.Seed);
            _step   = 0;
        }
    }

    private void TakeControlFromHere()
    {
        if (_result == null || _setup == null || _currentScenario == null) return;
        var snap   = _result.Snapshots[_step];
        _startRequest  = new ResumeFromSnapshotRequest(snap.UnitStates, snap.Event.ActorId, _step + 1);
        _actionHistory = [];
        _session  = new InteractiveBattleSession(_setup, _currentScenario.Seed);
        _response = _session.HandleRequest(_startRequest);
        SelectDefaultSkill();
        _playMode = true;
        _result   = null;
        if (_autoMode) _ = RunAutoAsync();
    }

    private void ToggleAuto()
    {
        _autoMode = !_autoMode;
        if (_autoMode && _session != null && _response?.PendingInput != null && !(_response.IsOver))
            _ = RunAutoAsync();
    }

    private async Task RunAutoAsync()
    {
        while (_autoMode && _session != null && _response?.PendingInput != null && !(_response?.IsOver ?? true))
        {
            await Task.Delay(_autoDelay);
            if (!_autoMode || _session == null) break;
            _actionHistory.Add(new ActionRecord(true, null, null, _response!.FullLog.Count));
            _response = _session.HandleRequest(new AutoPlayerActionRequest());
            SpawnFloats(_response);
            SelectDefaultSkill();
            StateHasChanged();
        }
    }

    private void FireAoe(string skillId)
    {
        if (_session is null) return;
        _actionHistory.Add(new ActionRecord(false, skillId, null, _response!.FullLog.Count));
        _response = _session.HandleRequest(new PlayerActionRequest(skillId, null));
        SpawnFloats(_response);
        SelectDefaultSkill();
    }

    private void ConfirmTarget(string targetId)
    {
        if (_session is null || _pendingAction is null) return;
        _actionHistory.Add(new ActionRecord(false, _pendingAction, targetId, _response!.FullLog.Count));
        _response = _session.HandleRequest(new PlayerActionRequest(_pendingAction, targetId));
        SpawnFloats(_response);
        SelectDefaultSkill();
    }


    // ── Undo ──────────────────────────────────────────────────────
    private void UndoToEvent(int logIndex)
    {
        if (_session == null || _setup == null || _currentScenario == null || _startRequest == null) return;
        if (_autoMode) return;

        // Count how many actions to replay: action j is replayed only if ALL its
        // produced events are strictly before logIndex (next action's LogCountBefore <= logIndex).
        int actionsToReplay = 0;
        for (int j = 0; j < _actionHistory.Count; j++)
        {
            int nextLogCount = j + 1 < _actionHistory.Count
                ? _actionHistory[j + 1].LogCountBefore
                : _response!.FullLog.Count;
            if (nextLogCount <= logIndex)
                actionsToReplay = j + 1;
            else
                break;
        }

        var newSession = new InteractiveBattleSession(_setup, _currentScenario.Seed);
        BattleResponse resp = newSession.HandleRequest(_startRequest);
        for (int j = 0; j < actionsToReplay; j++)
        {
            var a = _actionHistory[j];
            BattleRequest req = a.IsAuto
                ? new AutoPlayerActionRequest()
                : new PlayerActionRequest(a.SkillId!, a.TargetId);
            resp = newSession.HandleRequest(req);
        }

        _session       = newSession;
        _response      = resp;
        _actionHistory = _actionHistory.Take(actionsToReplay).ToList();
        _floats.Clear();
        SelectDefaultSkill();
    }

    // ── Default skill selection ───────────────────────────────────
    /// <summary>Pre-selects the same skill the auto AI would pick (last available).
    /// Called whenever _response changes in play mode.</summary>
    private void SelectDefaultSkill()
    {
        var p = _response?.PendingInput;
        if (p is null) { _pendingAction = null; return; }
        var def = p.Skills.LastOrDefault(s => p.AvailableSkillIds.Contains(s.Id));
        _pendingAction = def?.Id;
    }

    // ── Watch mode helpers ────────────────────────────────────────
    private BattleSnapshot? CurrentSnapshot => _result?.Snapshots[_step];
    private void StepForward() => _step = Math.Min(_step + 1, (_result?.Snapshots.Count ?? 1) - 1);
    private void StepBack()    => _step = Math.Max(0, _step - 1);
    private void JumpToStart() => _step = 0;
    private void JumpToEnd()   => _step = (_result?.Snapshots.Count ?? 1) - 1;

    // ── Floating numbers ─────────────────────────────────────────
    private record FloatNumber(string UnitId, int Value, bool IsHeal, int OffsetPct, int Key);
    private readonly List<FloatNumber> _floats = [];
    private int _floatKey = 0;

    private void SpawnFloats(BattleResponse? response)
    {
        if (response is null) return;
        foreach (var ev in response.NewEvents)
        {
            if (ev.TargetId is null || ev.Value <= 0) continue;
            bool isHeal = ev.Type == "skill" && ev.Description.Contains("heal", StringComparison.OrdinalIgnoreCase);
            int offset  = 20 + (_floatKey % 5) * 12;   // spread horizontally so multi-hits don't stack
            _floats.Add(new FloatNumber(ev.TargetId, ev.Value, isHeal, offset, _floatKey++));
        }
        if (_floats.Count > 0)
            _ = ExpireFloatsAsync();
    }

    private async Task ExpireFloatsAsync()
    {
        await Task.Delay(1100);   // matches CSS animation duration
        _floats.Clear();
        StateHasChanged();
    }
}

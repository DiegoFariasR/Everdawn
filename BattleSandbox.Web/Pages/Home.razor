@page "/"
@using GameCore.Battle
@using GameCore.Scenarios

<PageTitle>Battle Sandbox</PageTitle>

<div class="sandbox">

    <!-- ── Picker bar ─────────────────────────────────────────── -->
    <section class="picker">
        <div class="picker-row">
            <label for="scenario">Scenario</label>
            <select id="scenario" @bind="_selectedScenarioId">
                @foreach (var s in _scenarios)
                {
                    <option value="@s.Id">@s.DisplayName @(s.IsPlayable ? "🎮" : "👁")</option>
                }
            </select>
            <button class="btn-run" @onclick="StartSession">▶ Start</button>
        </div>
        <div class="picker-row">
            <label for="auto-speed">Speed</label>
            <select id="auto-speed" @bind="_autoDelay">
                <option value="200">Fast</option>
                <option value="600">Normal</option>
                <option value="1200">Slow</option>
            </select>
            <button class="btn-auto @(_autoMode ? "btn-auto-on" : "")" @onclick="ToggleAuto">
                ⚡ Auto @(_autoMode ? "ON" : "OFF")
            </button>
        </div>
    </section>

    @if (_playMode && _response != null && _setup != null)
    {
        var state   = _response.State;
        var lastEv  = _response.FullLog.LastOrDefault();
        string evType = lastEv?.Type ?? "start";
        var pending = _response.PendingInput;
        string? activeUnitId = pending?.Actor.Id ?? lastEv?.ActorId;

        <section class="portrait-strip">
            @foreach (var u in _setup.PlayerUnits)
            {
                var st = state.First(s => s.UnitId == u.Id);
                <div class="portrait player-portrait
                    @(activeUnitId == u.Id ? "portrait-active" : "")
                    @(!st.IsAlive ? "portrait-dead" : "")">
                    @u.Name[0]
                </div>
            }
            <div class="portrait-sep">⚔</div>
            @foreach (var u in _setup.EnemyUnits)
            {
                var st = state.First(s => s.UnitId == u.Id);
                <div class="portrait enemy-portrait
                    @(activeUnitId == u.Id ? "portrait-active" : "")
                    @(!st.IsAlive ? "portrait-dead" : "")">
                    @u.Name[0]
                </div>
            }
        </section>

        <section class="current-event @evType">
            @(lastEv?.Description ?? "Battle begins!")
        </section>

        <section class="arena">
            <div class="team player-team">
                @foreach (var u in _setup.PlayerUnits)
                {
                    var st = state.First(s => s.UnitId == u.Id);
                    int hpPct = u.MaxHp > 0 ? st.CurrentHp * 100 / u.MaxHp : 0;
                    int mpPct = u.MaxMp > 0 ? st.CurrentMp * 100 / u.MaxMp : 0;
                    string hpColor = hpPct > 50 ? "#44cc44" : hpPct > 25 ? "#ffaa00" : "#cc4444";
                    <div class="unit-card
                        @(activeUnitId == u.Id ? "card-active" : "")
                        @(!st.IsAlive ? "card-dead" : "")">
                        <div class="avatar player-avatar">@u.Name[0]</div>
                        <div class="unit-info">
                            <div class="unit-name">@u.Name <span class="unit-lv">Lv.@u.Level</span></div>
                            <div class="bar-wrap"><div class="hp-bar" style="width:@hpPct%;background:@hpColor"></div></div>
                            @if (u.MaxMp > 0)
                            {
                                <div class="bar-wrap"><div class="mp-bar" style="width:@mpPct%"></div></div>
                            }
                            <div class="stat-text">@st.CurrentHp/@u.MaxHp HP  @st.CurrentMp/@u.MaxMp MP</div>
                        </div>
                    </div>
                }
            </div>

            <div class="vs-col">vs</div>

            <!-- Enemy team — clickable for target selection -->
            <div class="team enemy-team">
                @foreach (var u in _setup.EnemyUnits)
                {
                    var st = state.First(s => s.UnitId == u.Id);
                    int hpPct = u.MaxHp > 0 ? st.CurrentHp * 100 / u.MaxHp : 0;
                    string hpColor = hpPct > 50 ? "#44cc44" : hpPct > 25 ? "#ffaa00" : "#cc4444";
                    bool canTarget = pending != null && _pendingAction != null && st.IsAlive && !_autoMode;

                    <div class="unit-card
                        @(activeUnitId == u.Id ? "card-active" : "")
                        @(!st.IsAlive ? "card-dead" : "")
                        @(canTarget ? "card-targetable" : "")"
                        @onclick="() => { if (canTarget) ConfirmTarget(u.Id); }">
                        <div class="avatar enemy-avatar">@u.Name[0]</div>
                        <div class="unit-info">
                            <div class="unit-name">@u.Name <span class="unit-lv">Lv.@u.Level</span></div>
                            <div class="bar-wrap"><div class="hp-bar" style="width:@hpPct%;background:@hpColor"></div></div>
                            <div class="stat-text">@st.CurrentHp/@u.MaxHp HP</div>
                        </div>
                    </div>
                }
            </div>
        </section>

        @if (pending != null)
        {
            <section class="action-bar">
                <div class="acting-label">
                    @(pending.Actor.Name + "'s turn")
                </div>
                @if (_autoMode)
                {
                    <div class="action-buttons">
                        <span style="opacity:0.6">⚡ Auto resolving…</span>
                    </div>
                }
                else if (_pendingAction == null)
                {
                    <div class="action-buttons">
                        @for (int si = 0; si < pending.Skills.Count; si++)
                        {
                            var skill   = pending.Skills[si];
                            bool canUse = pending.AvailableSkillIds.Contains(skill.Id);
                            string btnClass = si == 0 ? "btn-attack" : si == 1 ? "btn-skill" : "btn-soulburn";
                            string skillId  = skill.Id;
                            <button class="btn-action @btnClass"
                                    disabled="@(!canUse)"
                                    @onclick="() => _pendingAction = skillId">
                                @skill.Name
                                @if (skill.MpCost > 0)
                                {
                                    <span class="mp-cost">@skill.MpCost MP</span>
                                }
                            </button>
                        }
                    </div>
                }
                else
                {
                    string pendingSkillName = pending.Skills.FirstOrDefault(s => s.Id == _pendingAction)?.Name ?? _pendingAction!;
                    <div class="target-prompt">
                        <span class="target-prompt-label">@pendingSkillName — pick a target</span>
                        <button class="btn-cancel" @onclick="() => _pendingAction = null">✕ Cancel</button>
                    </div>
                }
            </section>
        }
        else if (_response.IsOver)
        {
            <section class="battle-over @(_response.WinningTeam == "player" ? "over-win" : "over-lose")">
                @(_response.WinningTeam == "player" ? "⚔ Victory!" : "💀 Defeat...")
                <button class="btn-run" style="margin-left:1rem" @onclick="StartSession">Retry</button>
            </section>
        }

        <section class="event-log" id="play-log">
            @foreach (var ev in _response.FullLog)
            {
                <div class="event-entry @ev.Type @(_response.FullLog.Count > 0 && _response.FullLog[^1] == ev ? "event-current" : "")">
                    @ev.Description
                </div>
            }
        </section>
    }

    @if (!_playMode && _result != null && _setup != null)
    {
        var snap = CurrentSnapshot!;

        <section class="portrait-strip">
            @foreach (var u in _setup.PlayerUnits)
            {
                var st = snap.UnitStates.First(s => s.UnitId == u.Id);
                <div class="portrait player-portrait @(snap.Event.ActorId == u.Id ? "portrait-active" : "") @(!st.IsAlive ? "portrait-dead" : "")">
                    @u.Name[0]
                </div>
            }
            <div class="portrait-sep">⚔</div>
            @foreach (var u in _setup.EnemyUnits)
            {
                var st = snap.UnitStates.First(s => s.UnitId == u.Id);
                <div class="portrait enemy-portrait @(snap.Event.ActorId == u.Id ? "portrait-active" : "") @(!st.IsAlive ? "portrait-dead" : "")">
                    @u.Name[0]
                </div>
            }
        </section>

        <section class="current-event @snap.Event.Type">@snap.Event.Description</section>

        <section class="arena">
            <div class="team player-team">
                @foreach (var u in _setup.PlayerUnits)
                {
                    var st = snap.UnitStates.First(s => s.UnitId == u.Id);
                    int hpPct = u.MaxHp > 0 ? st.CurrentHp * 100 / u.MaxHp : 0;
                    int mpPct = u.MaxMp > 0 ? st.CurrentMp * 100 / u.MaxMp : 0;
                    string hpColor = hpPct > 50 ? "#44cc44" : hpPct > 25 ? "#ffaa00" : "#cc4444";
                    <div class="unit-card @(snap.Event.ActorId == u.Id ? "card-active" : "") @(!st.IsAlive ? "card-dead" : "")">
                        <div class="avatar player-avatar">@u.Name[0]</div>
                        <div class="unit-info">
                            <div class="unit-name">@u.Name <span class="unit-lv">Lv.@u.Level</span></div>
                            <div class="bar-wrap"><div class="hp-bar" style="width:@hpPct%;background:@hpColor"></div></div>
                            @if (u.MaxMp > 0) { <div class="bar-wrap"><div class="mp-bar" style="width:@mpPct%"></div></div> }
                            <div class="stat-text">@st.CurrentHp/@u.MaxHp HP</div>
                        </div>
                    </div>
                }
            </div>
            <div class="vs-col">vs</div>
            <div class="team enemy-team">
                @foreach (var u in _setup.EnemyUnits)
                {
                    var st = snap.UnitStates.First(s => s.UnitId == u.Id);
                    int hpPct = u.MaxHp > 0 ? st.CurrentHp * 100 / u.MaxHp : 0;
                    int mpPct = u.MaxMp > 0 ? st.CurrentMp * 100 / u.MaxMp : 0;
                    string hpColor = hpPct > 50 ? "#44cc44" : hpPct > 25 ? "#ffaa00" : "#cc4444";
                    <div class="unit-card @(snap.Event.ActorId == u.Id ? "card-active" : "") @(!st.IsAlive ? "card-dead" : "")">
                        <div class="avatar enemy-avatar">@u.Name[0]</div>
                        <div class="unit-info">
                            <div class="unit-name">@u.Name <span class="unit-lv">Lv.@u.Level</span></div>
                            <div class="bar-wrap"><div class="hp-bar" style="width:@hpPct%;background:@hpColor"></div></div>
                            @if (u.MaxMp > 0) { <div class="bar-wrap"><div class="mp-bar" style="width:@mpPct%"></div></div> }
                            <div class="stat-text">@st.CurrentHp/@u.MaxHp HP</div>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="step-controls">
            <button @onclick="JumpToStart">◀◀</button>
            <button @onclick="StepBack">◀</button>
            <span class="step-label">@(_step + 1) / @_result.Snapshots.Count</span>
            <button @onclick="StepForward">▶</button>
            <button @onclick="JumpToEnd">▶▶</button>            <button class="btn-takeover" @onclick="TakeControlFromHere" title="Play from here">⚔ Take Control</button>        </section>

        <section class="event-log">
            @for (int i = 0; i < _result.Snapshots.Count; i++)
            {
                int idx = i;
                var s = _result.Snapshots[i];
                <div class="event-entry @(idx == _step ? "event-current" : "") @s.Event.Type" @onclick="() => _step = idx">
                    <span class="event-num">@(i + 1).</span> @s.Event.Description
                </div>
            }
        </section>
    }

</div>

@code {
    // ── Shared ──────────────────────────────────────────────────
    private List<IBattleScenario> _scenarios = [];
    private string _selectedScenarioId = "";
    private IBattleScenario? _currentScenario;
    private BattleSetup? _setup;
    private bool _playMode;

    // ── Play mode ────────────────────────────────────────────────
    private InteractiveBattleSession? _session;
    private BattleResponse? _response;
    private string? _pendingAction;   // skill ID selected, waiting for target
    private bool _autoMode;
    private int _autoDelay = 600;

    // ── Watch mode ───────────────────────────────────────────────
    private BattleResult? _result;
    private int _step;

    protected override void OnInitialized()
    {
        _scenarios = [new SampleScenario(), new SampleScenarioWatch()];
        _selectedScenarioId = _scenarios[0].Id;
    }

    private void StartSession()
    {
        _currentScenario = _scenarios.First(s => s.Id == _selectedScenarioId);
        _setup         = _currentScenario.CreateSetup();
        _playMode      = _currentScenario.IsPlayable;
        _session       = null;
        _response      = null;
        _result        = null;
        _pendingAction = null;

        if (_playMode)
        {
            _session  = new InteractiveBattleSession(_setup, _currentScenario.Seed);
            _response = _session.HandleRequest(new StartBattleRequest());
            if (_autoMode) _ = RunAutoAsync();
        }
        else
        {
            _result = BattleEngine.Run(_setup, _currentScenario.Seed);
            _step   = 0;
        }
    }

    private void TakeControlFromHere()
    {
        if (_result == null || _setup == null || _currentScenario == null) return;
        var snap = _result.Snapshots[_step];
        _session  = new InteractiveBattleSession(_setup, _currentScenario.Seed);
        _response = _session.HandleRequest(new ResumeFromSnapshotRequest(snap.UnitStates, snap.Event.ActorId, _step + 1));
        _pendingAction = null;
        _playMode = true;
        _result   = null;
        if (_autoMode) _ = RunAutoAsync();
    }

    private void ToggleAuto()
    {
        _autoMode = !_autoMode;
        if (_autoMode && _session != null && _response?.PendingInput != null && !(_response.IsOver))
            _ = RunAutoAsync();
    }

    private async Task RunAutoAsync()
    {
        while (_autoMode && _session != null && _response?.PendingInput != null && !(_response?.IsOver ?? true))
        {
            await Task.Delay(_autoDelay);
            if (!_autoMode || _session == null) break;
            _response = _session.HandleRequest(new AutoPlayerActionRequest());
            _pendingAction = null;
            StateHasChanged();
        }
    }

    private void ConfirmTarget(string targetId)
    {
        if (_session is null || _pendingAction is null) return;
        _response = _session.HandleRequest(new PlayerActionRequest(_pendingAction, targetId));
        _pendingAction = null;
    }


    // ── Watch mode helpers ────────────────────────────────────────
    private BattleSnapshot? CurrentSnapshot => _result?.Snapshots[_step];
    private void StepForward() => _step = Math.Min(_step + 1, (_result?.Snapshots.Count ?? 1) - 1);
    private void StepBack()    => _step = Math.Max(0, _step - 1);
    private void JumpToStart() => _step = 0;
    private void JumpToEnd()   => _step = (_result?.Snapshots.Count ?? 1) - 1;
}

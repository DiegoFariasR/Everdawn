<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.4" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.4" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GameCore\GameCore.csproj" />
    <ProjectReference Include="..\GameCore.Scenarios\GameCore.Scenarios.csproj" />
  </ItemGroup>

  <!--
    Before each build:
      1. Generate content-index.json from all *.yml files in GameData/Base/.
         This file is auto-generated — never edit it by hand. It is committed to
         the repo so that the last known state is visible in diffs, but it is
         always overwritten here before the YAML files are copied to wwwroot.
      2. Copy GameData/Base YAML files (including the freshly-written index) into
         wwwroot/GameData/Base/ so the Blazor WASM dev server can serve them via HTTP.
      3. Delete the incremental static asset manifest caches so the manifest is
         always rebuilt from the current wwwroot contents (required because MSBuild
         evaluates the wwwroot/** item glob at project-load time, before any targets
         run — new files copied by step 2 would otherwise not appear in the manifest
         until the next build).
  -->
  <Target Name="CopyGameDataToWwwroot" BeforeTargets="BeforeBuild">
    <!-- Step 1: regenerate content-index.json from the actual YAML files on disk -->
    <Exec Condition="'$(OS)' == 'Windows_NT'"
          Command="powershell -NoProfile -NonInteractive -Command &quot;$b = (Resolve-Path '$(MSBuildProjectDirectory)\..\GameData\Base').Path; $fs = @(Get-ChildItem -Path $b -Recurse -Filter '*.yml' | ForEach-Object { $_.FullName.Substring($b.Length + 1).Replace('\', '/') } | Sort-Object); [System.IO.File]::WriteAllText((Join-Path $b 'content-index.json'), (ConvertTo-Json $fs), [System.Text.Encoding]::UTF8)&quot;" />
    <Exec Condition="'$(OS)' != 'Windows_NT'"
          Command="python3 -c &quot;import json, pathlib; base = pathlib.Path('$(MSBuildProjectDirectory)/../GameData/Base'); files = sorted(p.relative_to(base).as_posix() for p in base.rglob('*.yml')); base.joinpath('content-index.json').write_text(json.dumps(files, indent=2) + chr(10))&quot;" />

    <!-- Step 2: copy all GameData/Base files (including the generated index) to wwwroot -->
    <ItemGroup>
      <_GameDataSource Include="..\GameData\Base\**" />
    </ItemGroup>
    <Copy SourceFiles="@(_GameDataSource)"
          DestinationFiles="@(_GameDataSource->'$(MSBuildProjectDirectory)\wwwroot\GameData\Base\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

    <!-- Step 3: invalidate incremental static asset manifest caches -->
    <Delete Files="$(IntermediateOutputPath)staticwebassets.build.json.cache"
            Condition="Exists('$(IntermediateOutputPath)staticwebassets.build.json.cache')" />
    <Delete Files="$(IntermediateOutputPath)$(AssemblyName).assets.cache"
            Condition="Exists('$(IntermediateOutputPath)$(AssemblyName).assets.cache')" />
  </Target>

</Project>
